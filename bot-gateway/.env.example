# bot-gateway environment (copy to .env)

BOT_GATEWAY_TOKEN=replace-with-your-secret-token

# Workspace root (Knot 工作区)
WORKSPACE_ROOT=/data/workspace/amer-fpp-a

# ---------- 企业微信 API（二次开发） ----------
# 设为 true 启用 /api/wecom/callback
WECOM_ENABLED=false

# 企微管理后台 → 应用 → 自建应用
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_AGENT_SECRET=

# 企微管理后台 → 应用 → 接收消息 → API 接收
WECOM_CALLBACK_TOKEN=
WECOM_ENCODING_AES_KEY=

# 内网可访问域名（可选，用于文字消息里附带下载链接）
# 例：https://fpp-ai.internal
WECOM_PUBLIC_BASE_URL=

# 每次最多回传几个文件到 chat（企微单文件 ≤20MB）
WECOM_MAX_REPLY_FILES=3
WECOM_MAX_FILE_BYTES=20971520
