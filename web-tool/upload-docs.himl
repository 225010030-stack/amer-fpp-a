<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>FPP 文档生成页（上传即产出）</title>
  <style>
    body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 24px; color: #111; }
    .card { border: 1px solid #ddd; border-radius: 10px; padding: 14px; margin-top: 14px; }
    .row { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 8px; }
    input, button { padding: 10px; border: 1px solid #ccc; border-radius: 8px; }
    button { cursor: pointer; background: #fff; }
    button:hover { background: #f5f5f5; }
    pre { white-space: pre-wrap; background: #fafafa; border: 1px solid #eee; padding: 10px; border-radius: 8px; }
    .muted { color: #666; font-size: 12px; }
  </style>
</head>
<body>
  <h2>FPP 文档生成页（新页面）</h2>
  <p class="muted">用途：同事直接上传 CSV，直接得到文档输出。</p>

  <div class="card">
    <h3>后端连接</h3>
    <div class="row">
      <input id="apiBase" style="min-width:360px;" />
      <button onclick="saveApi()">保存</button>
      <button onclick="checkHealth()">健康检查</button>
    </div>
    <pre id="health">未检查</pre>
  </div>

  <div class="card">
    <h3>上传并生成文档</h3>
    <div class="row">
      <input id="uploadFile" type="file" accept=".csv,text/csv" />
      <button onclick="uploadAndGenerate('generate_submission_blocks')">生成提单文本块</button>
      <button onclick="uploadAndGenerate('hc_check_upload')">生成HC校验报告</button>
    </div>
    <pre id="result">等待上传...</pre>
    <div id="links"></div>
  </div>

  <script>
    const KEY = "fpp_api_base";
    let API = localStorage.getItem(KEY) || "http://127.0.0.1:18082";

    function init() {
      document.getElementById("apiBase").value = API;
    }

    function saveApi() {
      const v = document.getElementById("apiBase").value.trim();
      if (!v) return;
      API = v;
      localStorage.setItem(KEY, API);
      document.getElementById("health").textContent = `已保存：${API}`;
    }

    async function checkHealth() {
      const el = document.getElementById("health");
      el.textContent = "检查中...";
      try {
        const res = await fetch(`${API}/api/health`);
        const data = await res.json();
        el.textContent = JSON.stringify(data, null, 2);
      } catch (e) {
        el.textContent = `连接失败: ${e}`;
      }
    }

    function showLinks(data) {
      const box = document.getElementById("links");
      if (!data || !Array.isArray(data.outputs) || !data.outputs.length) {
        box.innerHTML = "<p class='muted'>无可下载文件</p>";
        return;
      }
      box.innerHTML = "<ul>" + data.outputs.map(p => {
        const url = `${API}/api/files?path=${encodeURIComponent(p)}`;
        return `<li><a href="${url}" target="_blank">${p}</a></li>`;
      }).join("") + "</ul>";
    }

    async function uploadAndGenerate(action) {
      const fileInput = document.getElementById("uploadFile");
      const el = document.getElementById("result");
      if (!fileInput.files || !fileInput.files.length) {
        el.textContent = "请先选择CSV文件。";
        return;
      }
      el.textContent = "上传处理中...";
      try {
        const fd = new FormData();
        fd.append("action", action);
        fd.append("root", "/Users/zhangwenjing/Desktop/工作提效");
        fd.append("file", fileInput.files[0]);
        const res = await fetch(`${API}/api/upload-and-generate`, { method: "POST", body: fd });
        const data = await res.json();
        el.textContent = JSON.stringify(data, null, 2);
        showLinks(data);
      } catch (e) {
        el.textContent = `上传失败: ${e}`;
      }
    }

    init();
  </script>
</body>
</html>
